{$APP_DOMAIN} {
  encode gzip zstd

  handle /api/* {
    reverse_proxy api:8000 {
      header_up X-Admin-Key {$FRONTEND_API_SECRET}
      transport http {
        read_timeout 120s
        write_timeout 30s
      }
    }
  }

  handle /health {
    reverse_proxy api:8000
  }

  handle {
    reverse_proxy frontend:80
  }
}
